# ================================================
# ProSensia Smart-Serve — Git Ignore
# ================================================

# ── Environment ──
.env
.env.local
.env.production

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
venv/
.venv/
*.egg

# ── Node.js ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── Build ──
frontend/build/
frontend/dist/

# ── Logs ──
*.log
backend/logs/*.log

# ── Database ──
*.sqlite3
backups/

# ── AI Model Files ──
ai_module/models/*.pkl
ai_module/data/*.csv

# ── Test ──
.coverage
htmlcov/
.pytest_cache/
coverage/

# ── Reports ──
automation/reports/*.txt
automation/reports/*.json

# ── Docker ──
docker-compose.override.yml

# ── Jupyter ──
.ipynb_checkpoints/

# ── OS ──
Thumbs.db
.DS_Store